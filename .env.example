# 复制本文件为 .env 并填入你的配置
GIWA_URL=https://你的-redmine-地址
# API key 在 Redmine → My account → API access key → Show 获取
GIWA_KEY=你的_api_key
# 可选：额外常驻任务（工单号逗号分隔），会一直出现在工时选择列表里。
# 内部/客户会议(Tareas internas/externas)已自动跨项目发现，无需在此添加；
# 这里用于加别的常用工单，例如某个 daily 任务。
# GIWA_EXTRA_TASKS=1234

# 可选：GitLab（只读）。配置后工时日历会显示本周提交/MR，并从分支名 GIWA<编号> 关联工单。
# token 在 GitLab → Edit profile → Access Tokens 创建，建议只勾 read_api + read_user（只读）。
# GITLAB_URL=https://你的-gitlab-地址
# GITLAB_TOKEN=你的_token
