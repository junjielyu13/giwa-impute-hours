# Copy this file to .env and fill in your config
GIWA_URL=https://your-redmine-host
# Get the API key from Redmine → My account → API access key → Show
GIWA_KEY=your_api_key
# Optional: extra persistent tasks (issue numbers, comma-separated); they always appear in the time-entry selection list.
# Internal/client meetings (Tareas internas/externas) are auto-discovered across projects, so no need to add them here;
# use this to add other frequently-used issues, e.g. a daily task.
# GIWA_EXTRA_TASKS=1234

# Optional: GitLab (read-only). Once configured, the time calendar shows this week's pushes/MRs and links branch names GIWA<number> to issues.
# Create the token in GitLab → Edit profile → Access Tokens; it's recommended to grant only read_api + read_user (read-only).
# GITLAB_URL=https://your-gitlab-host
# GITLAB_TOKEN=your_token
